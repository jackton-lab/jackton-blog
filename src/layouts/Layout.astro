---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Real Estate Intelligence. Audited by Data." } = Astro.props;
---

<!doctype html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Jackton</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={`${title} — Jackton`} />
  <meta property="og:description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600&family=Instrument+Sans:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
</head>
<body>

  <nav>
    <a href="/" class="nav-brand">
      <svg width="22" height="22" viewBox="0 0 1024 1024" fill="currentColor">
        <g transform="translate(0,1024) scale(0.1,-0.1)" stroke="none">
          <path d="M4105 8175 c-282 -62 -509 -283 -587 -570 -20 -77 -21 -101 -22 -560 l-1 -480 247 -3 247 -2 3 457 c3 453 3 458 26 508 30 65 75 112 137 141 50 24 52 24 409 24 337 0 358 -1 351 -17 -39 -94 -40 -115 -40 -636 l0 -508 72 -28 c137 -54 252 -130 360 -237 l62 -63 3 637 3 637 27 51 c28 53 85 111 140 141 31 17 80 18 728 21 527 2 706 0 740 -9 56 -16 149 -105 170 -164 11 -32 15 -137 17 -516 l4 -476 42 -12 c123 -36 293 -146 395 -254 29 -32 54 -57 55 -57 1 0 0 312 -3 692 l-5 693 -26 70 c-102 274 -287 447 -553 515 -78 20 -105 20 -1510 19 -1146 0 -1443 -3 -1491 -14z"/>
          <path d="M5810 6713 c0 -849 0 -837 -70 -980 -75 -152 -220 -277 -384 -329 -66 -21 -112 -27 -251 -35 -261 -13 -416 -55 -602 -161 -201 -115 -397 -332 -474 -526 -44 -112 -79 -170 -124 -210 -76 -66 -105 -72 -376 -72 -131 0 -273 -5 -316 -11 -267 -37 -486 -198 -597 -441 -64 -139 -66 -161 -66 -723 0 -574 1 -587 75 -740 94 -194 245 -326 460 -402 l80 -28 761 -3 c870 -3 843 -5 1010 78 189 93 331 256 393 451 34 108 41 216 41 669 0 416 1 437 21 480 26 58 72 105 134 138 l50 27 755 5 755 5 80 28 c229 80 407 257 489 485 l31 87 3 585 c3 671 4 664 -80 832 -92 184 -262 330 -458 394 -46 14 -107 18 -365 23 -295 6 -312 7 -352 29 -48 25 -89 74 -109 129 -10 30 -13 141 -14 506 l0 467 -250 0 -250 0 0 -757z"/>
        </g>
      </svg>
      JACKTON
    </a>
    <a href="https://jackton.xyz" target="_blank" class="nav-cta">Platform →</a>
  </nav>

  <slot />

  <footer>
    <div class="footer-inner">
      <p class="footer-brand">JACKTON INTELLIGENCE</p>
      <p class="footer-copy">© 2026 PT Jack Solusi Media</p>
    </div>
  </footer>

</body>
</html>

<style is:global>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --bg:      #080808;
    --surface: #111111;
    --border:  rgba(255,255,255,0.07);
    --fg:      #F2F0EC;
    --muted:   #74746E;
    --accent:  #C8B89A;
    --font-display: 'Sora', sans-serif;
    --font-body:    'Instrument Sans', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background: var(--bg);
    color: var(--fg);
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* ── NAV ────────────────────────────────── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; justify-content: space-between; align-items: center;
    padding: 0 48px;
    height: 64px;
    background: rgba(8,8,8,0.85);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-bottom: 1px solid var(--border);
  }
  .nav-brand {
    display: flex; align-items: center; gap: 10px;
    text-decoration: none; color: var(--fg);
    font-family: var(--font-display);
    font-size: 13px; font-weight: 600; letter-spacing: 2.5px;
  }
  .nav-cta {
    font-family: var(--font-display);
    font-size: 11px; font-weight: 500; letter-spacing: 1px;
    color: var(--bg); background: var(--fg);
    padding: 7px 18px; text-decoration: none;
    border-radius: 100px;
    transition: opacity 0.2s;
  }
  .nav-cta:hover { opacity: 0.8; }

  /* ── FOOTER ─────────────────────────────── */
  footer {
    margin-top: auto;
    border-top: 1px solid var(--border);
    padding: 40px 48px;
  }
  .footer-inner {
    display: flex; justify-content: space-between; align-items: center;
    max-width: 1160px; margin: 0 auto;
  }
  .footer-brand {
    font-family: var(--font-display);
    font-size: 10px; letter-spacing: 3px; color: var(--muted);
  }
  .footer-copy { font-size: 12px; color: var(--muted); opacity: 0.5; }

  @media (max-width: 768px) {
    nav { padding: 0 20px; }
    footer { padding: 32px 20px; }
    .footer-inner { flex-direction: column; gap: 12px; text-align: center; }
  }
</style>
