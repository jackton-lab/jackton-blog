---
import { type CollectionEntry, getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await post.render();
const date = post.data.pubDate.toLocaleDateString('id-ID', {
  weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
});
---

<Layout title={post.data.title} description={post.data.description}>

  <!-- HERO IMAGE -->
  {post.data.heroImage && (
    <div class="post-hero">
      <img src={post.data.heroImage} alt={post.data.title} loading="eager" />
      <div class="post-hero-fade" />
    </div>
  )}

  <div class="post-wrap">

    <!-- HEADER -->
    <header class="post-header">
      <a href="/" class="post-back">← Semua Artikel</a>
      <time class="post-date">{date}</time>
      <h1 class="post-title">{post.data.title}</h1>
      {post.data.description && (
        <p class="post-lead">{post.data.description}</p>
      )}
    </header>

    <hr class="post-rule" />

    <!-- BODY -->
    <div class="post-body">
      <Content />
    </div>

    <!-- FOOTER CTA -->
    <div class="post-cta">
      <div class="cta-box">
        <p class="cta-label">JACKTON INTELLIGENCE PLATFORM</p>
        <p class="cta-text">
          Akses data properti, analisis pasar, dan sinyal investasi real estate Indonesia secara langsung.
        </p>
        <a href="https://jackton.xyz" target="_blank" class="cta-btn">
          Buka Jackton Platform →
        </a>
      </div>
    </div>

    <div class="post-nav">
      <a href="/" class="post-nav-link">← Kembali ke Semua Artikel</a>
    </div>

  </div>

</Layout>

<style is:global>
  /* ── ARTICLE TYPOGRAPHY ──────────────────── */
  .post-body {
    font-family: var(--font-body);
    font-size: 17px; line-height: 1.85;
    color: rgba(242, 240, 236, 0.82);
    font-weight: 400;
  }
  .post-body p { margin-bottom: 1.6em; }
  .post-body h2 {
    font-family: var(--font-display);
    font-size: 22px; font-weight: 500;
    letter-spacing: -0.025em; line-height: 1.25;
    color: var(--fg); margin: 3em 0 1em;
    padding-top: 2em; border-top: 1px solid var(--border);
  }
  .post-body h3 {
    font-family: var(--font-display);
    font-size: 17px; font-weight: 500;
    color: var(--fg); margin: 2.2em 0 0.8em;
  }
  .post-body strong { color: var(--fg); font-weight: 500; }
  .post-body em { color: var(--accent); font-style: italic; }
  .post-body ul, .post-body ol { padding-left: 22px; margin-bottom: 1.6em; }
  .post-body li { margin-bottom: 0.5em; }
  .post-body blockquote {
    margin: 2.5em 0; padding: 20px 28px;
    border-left: 2px solid var(--accent);
    background: rgba(200,184,154,0.04);
    color: var(--accent); font-style: italic;
    border-radius: 0 8px 8px 0;
  }
  .post-body a {
    color: var(--fg); text-underline-offset: 3px;
    text-decoration-color: var(--border);
  }
  .post-body a:hover { text-decoration-color: var(--fg); }
</style>

<style>
  /* ── HERO ────────────────────────────────── */
  .post-hero {
    position: relative; width: 100%;
    height: min(56vw, 560px);
    overflow: hidden; background: #0a0a0a;
    margin-top: 64px; /* offset nav */
  }
  .post-hero img {
    width: 100%; height: 100%; object-fit: cover;
    display: block; opacity: 1 !important;
    filter: brightness(0.7) saturate(0.55);
  }
  .post-hero-fade {
    position: absolute; inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(8,8,8,0) 30%,
      rgba(8,8,8,0.6) 70%,
      rgba(8,8,8,1) 100%
    );
  }

  /* ── WRAP ────────────────────────────────── */
  .post-wrap {
    max-width: 720px; margin: 0 auto;
    padding: 0 24px 120px;
  }

  /* ── HEADER ──────────────────────────────── */
  .post-header { padding-top: 60px; margin-bottom: 48px; }
  .post-back {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 10px; letter-spacing: 2px;
    color: var(--muted); text-decoration: none;
    margin-bottom: 36px; opacity: 0.45;
    transition: opacity 0.2s;
  }
  .post-back:hover { opacity: 1; }
  .post-date {
    display: block;
    font-family: var(--font-display);
    font-size: 10px; letter-spacing: 2px;
    color: var(--muted); opacity: 0.45;
    margin-bottom: 20px; text-transform: capitalize;
  }
  .post-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 5vw, 52px);
    font-weight: 400; line-height: 1.1;
    letter-spacing: -0.04em; color: var(--fg);
    margin-bottom: 20px;
  }
  .post-lead {
    font-size: 18px; color: var(--muted);
    line-height: 1.65; font-weight: 400;
    border-left: 2px solid var(--accent);
    padding-left: 16px; margin-top: 4px;
  }

  /* ── RULE ────────────────────────────────── */
  .post-rule {
    border: none; border-top: 1px solid var(--border);
    margin-bottom: 56px;
  }

  /* ── CTA BOX ─────────────────────────────── */
  .post-cta { margin-top: 72px; }
  .cta-box {
    background: var(--surface);
    border-radius: 20px; padding: 44px 40px;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.05) inset,
      0 8px 32px rgba(0,0,0,0.5),
      0 32px 64px rgba(0,0,0,0.35);
  }
  .cta-label {
    font-family: var(--font-display);
    font-size: 9px; letter-spacing: 3px;
    color: var(--accent); opacity: 0.8;
    margin-bottom: 16px;
  }
  .cta-text {
    font-size: 15px; color: var(--muted);
    line-height: 1.7; margin-bottom: 28px;
  }
  .cta-btn {
    display: inline-block;
    background: var(--fg); color: var(--bg);
    padding: 13px 32px; border-radius: 100px;
    font-family: var(--font-display);
    font-size: 12px; font-weight: 600; letter-spacing: 0.5px;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
  }
  .cta-btn:hover { opacity: 0.85; transform: translateY(-1px); }

  /* ── POST NAV ────────────────────────────── */
  .post-nav { margin-top: 56px; text-align: center; }
  .post-nav-link {
    font-family: var(--font-display);
    font-size: 11px; letter-spacing: 1.5px;
    color: var(--muted); text-decoration: none;
    opacity: 0.35; transition: opacity 0.2s;
  }
  .post-nav-link:hover { opacity: 0.9; }

  @media (max-width: 768px) {
    .post-hero { height: 56vw; min-height: 240px; }
    .post-header { padding-top: 40px; }
    .cta-box { padding: 32px 24px; }
  }
</style>
