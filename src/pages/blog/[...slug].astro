---
import { type CollectionEntry, getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await post.render();
const formattedDate = post.data.pubDate.toLocaleDateString('id-ID', {
  day: 'numeric', month: 'long', year: 'numeric'
});
---

<Layout title={post.data.title} description={post.data.description}>
  <article>

    <!-- HERO -->
    {post.data.heroImage && (
      <div class="hero">
        <img src={post.data.heroImage} alt={post.data.title} loading="eager" />
        <div class="hero-fade" />
      </div>
    )}

    <div class="container">

      <!-- META -->
      <header class="post-header">
        <a href="/" class="back">← Semua Artikel</a>
        <p class="post-date">{formattedDate}</p>
        <h1 class="post-title">{post.data.title}</h1>
      </header>

      <div class="divider" />

      <!-- KONTEN -->
      <div class="post-body">
        <Content />
      </div>

      <!-- FOOTER -->
      <footer class="post-footer">
        <div class="footer-box">
          <p class="footer-label">JACKTON INTELLIGENCE</p>
          <p class="footer-text">
            Laporan ini dihasilkan oleh pipeline media otonom Jackton —<br />
            kurasi harian dari sinyal pasar properti Indonesia.
          </p>
          <a href="https://jackton.xyz" target="_blank" class="footer-cta">
            Akses Jackton Platform →
          </a>
        </div>
        <a href="/" class="footer-back">← Kembali ke Semua Artikel</a>
      </footer>

    </div>
  </article>
</Layout>

<style is:global>
  .post-body { color: var(--fg); line-height: 1.9; font-size: 1.06rem; font-weight: 300; }
  .post-body p { margin-bottom: 1.8rem; opacity: 0.85; }
  .post-body h2 {
    font-size: 1.35rem; font-weight: 500; letter-spacing: -0.03em;
    color: var(--fg); margin: 3.2rem 0 1rem;
    padding-top: 2rem; border-top: 1px solid var(--border);
  }
  .post-body h3 { font-size: 1.05rem; font-weight: 500; margin: 2rem 0 0.8rem; color: var(--fg); }
  .post-body strong { color: #fff; font-weight: 500; }
  .post-body ul, .post-body ol { margin-bottom: 1.8rem; padding-left: 20px; }
  .post-body li { margin-bottom: 0.5rem; opacity: 0.85; line-height: 1.7; }
  .post-body a { color: var(--fg); border-bottom: 1px solid var(--border); text-decoration: none; }
  .post-body a:hover { border-color: rgba(255,255,255,0.35); }
  .post-body blockquote {
    border-left: 2px solid rgba(255,255,255,0.12); padding: 16px 24px;
    margin: 2rem 0; color: var(--muted); font-style: italic;
  }
</style>

<style>
  /* ── HERO ────────────────────────────────── */
  .hero {
    width: 100%; height: 520px;
    position: relative; overflow: hidden;
    background: #0a0a0a;
  }
  .hero img {
    width: 100%; height: 100%; object-fit: cover;
    opacity: 1 !important;
    filter: brightness(0.65) saturate(0.6);
    display: block;
  }
  .hero-fade {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 30%, var(--bg) 100%);
  }

  /* ── CONTAINER ───────────────────────────── */
  .container {
    max-width: 720px; margin: 0 auto;
    padding: 0 24px 120px;
  }

  /* ── HEADER ──────────────────────────────── */
  .post-header { padding-top: 56px; margin-bottom: 48px; }
  .back {
    display: inline-block;
    font-family: 'DM Mono', monospace;
    font-size: 10px; letter-spacing: 2px;
    color: var(--muted); text-decoration: none;
    margin-bottom: 32px; opacity: 0.5;
    transition: opacity 0.2s;
  }
  .back:hover { opacity: 1; }
  .post-date {
    font-family: 'DM Mono', monospace;
    font-size: 10px; letter-spacing: 1.5px;
    color: var(--muted); opacity: 0.4;
    margin-bottom: 20px;
  }
  .post-title {
    font-size: clamp(28px, 4.5vw, 50px);
    font-weight: 500; line-height: 1.1;
    letter-spacing: -0.04em; color: var(--fg);
  }

  /* ── DIVIDER ─────────────────────────────── */
  .divider { height: 1px; background: var(--border); margin-bottom: 56px; }

  /* ── FOOTER ──────────────────────────────── */
  .post-footer { margin-top: 80px; }
  .footer-box {
    border: 1px solid var(--border);
    padding: 40px; margin-bottom: 48px;
  }
  .footer-label {
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 3px;
    color: var(--muted); opacity: 0.4;
    margin-bottom: 16px;
  }
  .footer-text {
    font-size: 14px; color: var(--muted);
    line-height: 1.75; font-weight: 300;
    margin-bottom: 28px; opacity: 0.7;
  }
  .footer-cta {
    display: inline-block;
    background: var(--fg); color: var(--bg);
    padding: 12px 28px; font-size: 11px;
    font-weight: 600; letter-spacing: 0.5px;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .footer-cta:hover { opacity: 0.8; }
  .footer-back {
    display: block; text-align: center;
    font-family: 'DM Mono', monospace;
    font-size: 10px; letter-spacing: 1.5px;
    color: var(--muted); text-decoration: none;
    opacity: 0.3; transition: opacity 0.2s;
  }
  .footer-back:hover { opacity: 0.8; }

  @media (max-width: 768px) {
    .hero { height: 300px; }
    .footer-box { padding: 28px 24px; }
  }
</style>
