---
import { type CollectionEntry, getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await post.render();
---

<Layout title={post.data.title} description={post.data.description}>
	<main class="post-container">
        <header class="post-header gsap-reveal">
            <div class="header-top">
                <a href="/" class="back-link">← BACK_TO_ARCHIVE</a>
                <span class="post-date">{post.data.pubDate.toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric' }).toUpperCase()}</span>
            </div>
			<h1 class="post-title">{post.data.title}</h1>
            <div class="tags-row">
                {post.data.tags.map(tag => <span class="tag">#{tag.toUpperCase()}</span>)}
            </div>
		</header>

        <hr class="divider gsap-reveal"/>

		<article class="post-content gsap-reveal">
			<Content />
		</article>

        <section class="post-footer gsap-reveal">
            <div class="disclaimer-box">
                <div class="box-title">SYSTEM_NOTICE</div>
                <p>
					This intelligence report is generated by Jackton's autonomous media pipeline.<br/>
					Analysis is based on curated market signals and AI-processed data.<br/>
					Visit jackton.xyz to access the full data platform.
				</p>
            </div>
            <div class="footer-actions">
				<a href="/" class="btn-secondary">RETURN_TO_BASE</a>
				<a href="https://jackton.xyz" target="_blank" class="btn-action">AKSES JACKTON PLATFORM →</a>
			</div>
        </section>
	</main>
</Layout>

<style is:global>
    /* Content Markdown Styling */
    .post-content { color: var(--fg); line-height: 1.8; font-size: 1.1rem; }
    .post-content p { margin-bottom: 2rem; opacity: 0.9; font-weight: 300; }
    .post-content h2 { color: #fff; margin: 3rem 0 1.5rem; font-size: 1.8rem; font-weight: 600; letter-spacing: -0.02em; }
    .post-content blockquote { border-left: 2px solid var(--border); padding-left: 24px; font-style: italic; color: var(--muted); margin: 3rem 0; }
    .post-content strong { color: #fff; font-weight: 600; }
    .post-content ul { margin-bottom: 2rem; padding-left: 20px; color: var(--fg); opacity: 0.9; }
    .post-content li { margin-bottom: 0.8rem; }
</style>

<style>
	.post-container { max-width: 800px; margin: 0 auto; padding: 180px 24px 100px; }
    
    .header-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; }
    .back-link { font-family: monospace; font-size: 11px; text-decoration: none; color: var(--muted); transition: 0.3s; letter-spacing: 1px; }
    .back-link:hover { color: #fff; }
    .post-date { font-family: monospace; font-size: 11px; color: var(--muted); }

    .post-title { font-size: clamp(32px, 5vw, 56px); font-weight: 600; line-height: 1.1; letter-spacing: -0.04em; color: #fff; margin-bottom: 24px; }
    .tags-row { display: flex; gap: 16px; flex-wrap: wrap; }
    .tag { font-family: monospace; font-size: 10px; color: var(--muted); letter-spacing: 1px; }

    .divider { border: 0; border-top: 1px solid var(--border); margin: 60px 0; }

    .post-footer { margin-top: 100px; display: flex; flex-direction: column; align-items: center; gap: 40px; }
    .disclaimer-box { width: 100%; padding: 32px; background: rgba(255,255,255,0.02); border: 1px solid var(--border); border-radius: 12px; }
    .box-title { font-family: monospace; font-size: 10px; font-weight: bold; color: var(--muted); margin-bottom: 16px; letter-spacing: 2px; }
    .disclaimer-box p { font-size: 13px; color: var(--muted); line-height: 1.8; font-weight: 300; }

    .footer-actions { display: flex; flex-direction: column; align-items: center; gap: 16px; width: 100%; }

    .btn-action {
        background: var(--fg); color: var(--bg); padding: 16px 40px; border-radius: 100px;
        font-size: 12px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
		text-decoration: none; transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		text-align: center;
    }
	.btn-action:hover { transform: scale(1.05); }

	.btn-secondary {
		color: var(--muted); font-size: 11px; font-family: monospace; letter-spacing: 1px;
		text-decoration: none; transition: color 0.3s;
	}
	.btn-secondary:hover { color: #fff; }

	@media (max-width: 768px) {
		.post-container { padding-top: 120px; }
		.post-title { font-size: 32px; }
	}
</style>
