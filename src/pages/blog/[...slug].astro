---
import { type CollectionEntry, getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await post.render();
const formattedDate = post.data.pubDate.toLocaleDateString('id-ID', {
  day: 'numeric', month: 'long', year: 'numeric'
});
---

<Layout title={post.data.title} description={post.data.description}>
  <div class="page-wrapper">
    <article class="article-card" id="article-card">

      <!-- HERO IMAGE -->
      {post.data.heroImage && (
        <div class="hero">
          <img src={post.data.heroImage} alt={post.data.title} loading="eager" decoding="async" />
        </div>
      )}

      <!-- WINDOW CHROME (macOS-style title bar) -->
      <div class="window-chrome">
        <a href="/" class="chrome-back">← Semua Artikel</a>
        <div class="chrome-spacer"></div>
      </div>

      <!-- CONTENT -->
      <div class="content">
        <header class="post-header">
          <p class="post-date">{formattedDate}</p>
          <h1 class="post-title">{post.data.title}</h1>
          {post.data.description && (
            <p class="post-desc">{post.data.description}</p>
          )}
        </header>

        <div class="divider" />

        <div class="post-body">
          <Content />
        </div>

        <footer class="post-footer">
          <div class="signal-box">
            <p class="signal-label">JACKTON · PROPERTY INTELLIGENCE</p>
            <p class="signal-text">
              Analisis ini merupakan bagian dari kurasi harian sinyal pasar properti Indonesia
              yang dihasilkan secara otomatis dari sumber-sumber global terpilih.
            </p>
            <a href="https://jackton.xyz" target="_blank" class="signal-cta">
              Buka Jackton Platform →
            </a>
          </div>
          <a href="/" class="footer-back">← Kembali ke Semua Artikel</a>
        </footer>
      </div>

    </article>
  </div>
</Layout>

<style is:global>
  .post-body {
    color: var(--fg);
    line-height: 1.9;
    font-size: 1.04rem;
    font-weight: 300;
  }
  .post-body p { margin-bottom: 1.75rem; opacity: 0.82; }
  .post-body h2 {
    font-size: 1.2rem; font-weight: 500; letter-spacing: -0.03em;
    color: var(--fg); margin: 3rem 0 1rem;
    padding-top: 2rem; border-top: 1px solid var(--border);
  }
  .post-body h3 { font-size: 1rem; font-weight: 500; margin: 2rem 0 0.75rem; color: var(--fg); }
  .post-body strong { color: #fff; font-weight: 500; }
  .post-body ul, .post-body ol { margin-bottom: 1.75rem; padding-left: 20px; }
  .post-body li { margin-bottom: 0.5rem; opacity: 0.8; line-height: 1.75; }
  .post-body a { color: var(--fg); border-bottom: 1px solid var(--border); text-decoration: none; }
  .post-body a:hover { border-color: rgba(255,255,255,0.3); }
  .post-body blockquote {
    border-left: 2px solid rgba(255,255,255,0.1);
    padding: 14px 24px; margin: 2rem 0;
    color: var(--muted); font-style: italic;
  }
</style>

<style>
  .page-wrapper {
    min-height: 100vh;
    padding: 112px 24px 140px;
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  /* ── FLOATING CARD — Apple macOS glass window ── */
  .article-card {
    width: 100%;
    max-width: 800px;
    border-radius: 14px;
    overflow: hidden;
    background: rgba(18, 18, 20, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.10);
    box-shadow:
      0 0 0 0.5px rgba(255,255,255,0.06) inset,
      0 1px 0 rgba(255,255,255,0.10) inset,
      0 2px 6px rgba(0,0,0,0.25),
      0 8px 24px rgba(0,0,0,0.35),
      0 24px 64px rgba(0,0,0,0.30),
      0 64px 120px rgba(0,0,0,0.20);
    backdrop-filter: blur(40px) saturate(180%);
    -webkit-backdrop-filter: blur(40px) saturate(180%);
  }

  /* ── WINDOW CHROME (macOS title bar) ── */
  .window-chrome {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 20px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .chrome-back {
    font-family: 'DM Mono', monospace;
    font-size: 10px; letter-spacing: 1.5px;
    color: var(--muted); text-decoration: none;
    opacity: 0.45; transition: opacity 0.2s;
  }
  .chrome-back:hover { opacity: 0.9; }
  .chrome-spacer { flex: 1; }

  /* ── HERO ── */
  .hero {
    position: relative;
    height: 340px;
    overflow: hidden;
    background: #080809;
  }
  .hero img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
  }

  /* ── CONTENT ── */
  .content { padding: 40px 52px 52px; }

  .post-header { margin-bottom: 32px; }
  .post-date {
    font-family: 'DM Mono', monospace;
    font-size: 10px; letter-spacing: 1.5px;
    color: var(--muted); opacity: 0.35;
    margin-bottom: 14px;
    text-transform: uppercase;
  }
  .post-title {
    font-size: clamp(22px, 3.5vw, 40px);
    font-weight: 500; line-height: 1.12;
    letter-spacing: -0.04em; color: var(--fg);
    margin-bottom: 14px;
  }
  .post-desc {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.7;
    font-weight: 300;
    opacity: 0.55;
  }

  .divider { height: 1px; background: var(--border); margin-bottom: 40px; }

  /* ── SIGNAL BOX ── */
  .post-footer { margin-top: 64px; }
  .signal-box {
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 10px;
    padding: 28px 32px;
    background: rgba(255,255,255,0.025);
    margin-bottom: 32px;
  }
  .signal-label {
    font-family: 'DM Mono', monospace;
    font-size: 9px; letter-spacing: 3px;
    color: var(--muted); opacity: 0.3;
    margin-bottom: 10px;
    text-transform: uppercase;
  }
  .signal-text {
    font-size: 13px; color: var(--muted);
    line-height: 1.75; font-weight: 300;
    margin-bottom: 20px; opacity: 0.55;
  }
  .signal-cta {
    display: inline-block;
    background: var(--fg); color: var(--bg);
    padding: 9px 20px; font-size: 11px;
    font-weight: 600; letter-spacing: 0.5px;
    text-decoration: none; border-radius: 7px;
    transition: opacity 0.2s;
  }
  .signal-cta:hover { opacity: 0.8; }

  .footer-back {
    display: block; text-align: center;
    font-family: 'DM Mono', monospace;
    font-size: 10px; letter-spacing: 1.5px;
    color: var(--muted); text-decoration: none;
    opacity: 0.2; transition: opacity 0.2s;
  }
  .footer-back:hover { opacity: 0.7; }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .page-wrapper { padding: 80px 12px 100px; }
    .article-card { border-radius: 12px; }
    .hero { height: 200px; }
    .content { padding: 24px 20px 32px; }
    .signal-box { padding: 20px 18px; }
  }
</style>
