---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const title = "Intelligence Archive";
---

<Layout title={title}>
  <main class="container">

    <section class="hero gsap-reveal">
      <p class="hero-label">JACKTON INTELLIGENCE</p>
      <h1 class="hero-title">Intelligence Archive.</h1>
      <p class="hero-sub">Property market signals. Surfaced daily by Jackton.</p>
    </section>

    <div class="stats-bar gsap-reveal">
      <span class="stats-item">SISTEM AKTIF</span>
      <span class="stats-divider">·</span>
      <span class="stats-item">PIPELINE 24/7</span>
      <span class="stats-divider">·</span>
      <span class="stats-item">blog.jackton.xyz</span>
    </div>

    <section class="archive-section">
      {posts.length > 0 ? (
        <div class="report-grid">
          {posts.map((post, i) => (
            <a href={`/blog/${post.slug}`} class={`report-card gsap-reveal ${i === 0 ? 'card-featured' : ''}`}>
              <div class="card-thumb">
                {post.data.heroImage ? (
                  <img src={post.data.heroImage} alt={post.data.title} decoding="async" />
                ) : (
                  <div class="card-thumb-placeholder">
                    <svg width="32" height="32" viewBox="0 0 1024 1024" fill="rgba(255,255,255,0.1)">
                      <g transform="translate(0,1024) scale(0.1,-0.1)" stroke="none">
                        <path d="M4105 8175 c-282 -62 -509 -283 -587 -570 -20 -77 -21 -101 -22 -560 l-1 -480 247 -3 247 -2 3 457 c3 453 3 458 26 508 30 65 75 112 137 141 50 24 52 24 409 24 337 0 358 -1 351 -17 -39 -94 -40 -115 -40 -636 l0 -508 72 -28 c137 -54 252 -130 360 -237 l62 -63 3 637 3 637 27 51 c28 53 85 111 140 141 31 17 80 18 728 21 527 2 706 0 740 -9 56 -16 149 -105 170 -164 11 -32 15 -137 17 -516 l4 -476 42 -12 c123 -36 293 -146 395 -254 29 -32 54 -57 55 -57 1 0 0 312 -3 692 l-5 693 -26 70 c-102 274 -287 447 -553 515 -78 20 -105 20 -1510 19 -1146 0 -1443 -3 -1491 -14z"/>
                      </g>
                    </svg>
                  </div>
                )}
                <div class="card-thumb-overlay"></div>
                <div class="card-thumb-meta">
                  <span class="card-thumb-date">
                    {post.data.pubDate.toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }).toUpperCase()}
                  </span>
                  <span class="card-thumb-arrow">↗</span>
                </div>
              </div>
              <div class="card-content">
                <div class="card-tags">
                  {post.data.tags.slice(0, 3).map(tag => (
                    <span class="tag">{tag.toUpperCase()}</span>
                  ))}
                </div>
                <h2 class="card-title">{post.data.title}</h2>
                {post.data.description && (
                  <p class="card-desc">{post.data.description}</p>
                )}
                <div class="card-footer">
                  <div class="card-read-cta">
                    <span>Baca selengkapnya</span>
                    <span class="cta-arrow">→</span>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="empty-state gsap-reveal">
          <div class="empty-icon">
            <svg width="48" height="48" viewBox="0 0 1024 1024" fill="rgba(255,255,255,0.1)">
              <g transform="translate(0,1024) scale(0.1,-0.1)" stroke="none">
                <path d="M4105 8175 c-282 -62 -509 -283 -587 -570 -20 -77 -21 -101 -22 -560 l-1 -480 247 -3 247 -2 3 457 c3 453 3 458 26 508 30 65 75 112 137 141 50 24 52 24 409 24 337 0 358 -1 351 -17 -39 -94 -40 -115 -40 -636 l0 -508 72 -28 c137 -54 252 -130 360 -237 l62 -63 3 637 3 637 27 51 c28 53 85 111 140 141 31 17 80 18 728 21 527 2 706 0 740 -9 56 -16 149 -105 170 -164 11 -32 15 -137 17 -516 l4 -476 42 -12 c123 -36 293 -146 395 -254 29 -32 54 -57 55 -57 1 0 0 312 -3 692 l-5 693 -26 70 c-102 274 -287 447 -553 515 -78 20 -105 20 -1510 19 -1146 0 -1443 -3 -1491 -14z"/>
              </g>
            </svg>
          </div>
          <code>PIPELINE INITIALIZING — FIRST SIGNAL INCOMING 08:00 WIB</code>
        </div>
      )}
    </section>

  </main>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 160px 40px 100px;
  }

  /* HERO */
  .hero { text-align: center; margin-bottom: 64px; }
  .hero-label {
    font-family: monospace;
    font-size: 10px;
    letter-spacing: 4px;
    color: var(--muted);
    margin-bottom: 24px;
    display: block;
    opacity: 0.6;
  }
  .hero-title {
    font-size: clamp(40px, 6vw, 80px);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 20px;
    color: var(--fg);
  }
  .hero-sub {
    font-size: clamp(14px, 1.8vw, 17px);
    color: var(--muted);
    font-weight: 300;
    letter-spacing: 0.2px;
  }

  /* STATS BAR */
  .stats-bar {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    padding: 14px;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-bottom: 64px;
    font-family: monospace;
    font-size: 10px;
    letter-spacing: 2.5px;
    color: var(--muted);
  }
  .stats-divider { opacity: 0.2; }

  /* GRID */
  .report-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  /* CARD */
  .report-card {
    background: #060606;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: background 0.3s ease;
    overflow: hidden;
    position: relative;
  }
  .report-card:hover { background: #0d0d0d; }
  .report-card:hover .cta-arrow { transform: translateX(4px); }
  .report-card:hover .card-thumb img { transform: scale(1.04); filter: brightness(0.95); }
  .report-card:hover .card-thumb-overlay { opacity: 0.5; }
  .report-card:hover .card-thumb-meta { opacity: 1; }

  /* FEATURED — artikel pertama lebih lebar */
  .card-featured {
    grid-column: span 2;
  }
  .card-featured .card-title { font-size: 22px; }

  /* THUMBNAIL */
  .card-thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #111;
    position: relative;
    flex-shrink: 0;
  }
  .card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), filter 0.4s ease;
    filter: brightness(0.8) saturate(0.9);
  }
  .card-thumb-placeholder {
    width: 100%;
    height: 100%;
    background: #0a0a0a;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card-thumb-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 60%);
    transition: opacity 0.3s;
    opacity: 0.7;
  }
  .card-thumb-meta {
    position: absolute;
    bottom: 16px;
    left: 20px;
    right: 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    opacity: 0.8;
    transition: opacity 0.3s;
  }
  .card-thumb-date {
    font-family: monospace;
    font-size: 9px;
    color: rgba(255,255,255,0.7);
    letter-spacing: 1.5px;
  }
  .card-thumb-arrow {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
  }

  /* CARD CONTENT */
  .card-content {
    padding: 24px 24px 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 10px;
  }
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .tag {
    font-family: monospace;
    font-size: 8px;
    color: var(--muted);
    letter-spacing: 1.5px;
    opacity: 0.5;
    padding: 2px 8px;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 100px;
  }
  .card-title {
    font-size: 16px;
    font-weight: 600;
    line-height: 1.45;
    color: var(--fg);
    letter-spacing: -0.02em;
  }
  .card-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.65;
    font-weight: 300;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    opacity: 0.8;
  }
  .card-footer {
    margin-top: auto;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }
  .card-read-cta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 500;
    color: var(--muted);
    letter-spacing: 0.3px;
  }
  .cta-arrow {
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    font-size: 13px;
  }

  /* EMPTY STATE */
  .empty-state {
    text-align: center;
    padding: 140px 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }
  .empty-state code {
    font-family: monospace;
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 1.5px;
    opacity: 0.5;
  }

  @media (max-width: 900px) {
    .container { padding: 120px 24px 80px; }
    .report-grid { grid-template-columns: 1fr; }
    .card-featured { grid-column: span 1; }
    .card-featured .card-title { font-size: 18px; }
    .stats-bar { font-size: 9px; gap: 12px; }
  }
</style>
