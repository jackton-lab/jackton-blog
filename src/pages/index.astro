---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = "Intelligence Archive";
---

<Layout title={title}>
	<main class="container">
		<!-- HERO SECTION -->
		<section class="hero gsap-reveal">
			<h1 class="hero-title">Intelligence Archive.</h1>
			<p class="hero-sub">Property market signals. Surfaced daily by Jackton.</p>
		</section>

		<!-- STATS BAR -->
		<div class="stats-bar gsap-reveal">
			<span class="stats-item">SISTEM AKTIF</span>
			<span class="stats-divider">·</span>
			<span class="stats-item">PIPELINE 24/7</span>
			<span class="stats-divider">·</span>
			<span class="stats-item">blog.jackton.xyz</span>
		</div>

		<!-- GRID SECTION -->
		<section class="archive-section">
			{posts.length > 0 ? (
				<div class="report-grid">
					{posts.map((post) => (
						<a href={`/blog/${post.slug}`} class="report-card gsap-reveal">
							{/* THUMBNAIL */}
							{post.data.heroImage && (
								<div class="card-thumb">
									<img
										src={post.data.heroImage}
										alt={post.data.title}
										loading="lazy"
									/>
								</div>
							)}
							{/* KONTEN CARD */}
							<div class="card-content">
								<div class="card-tags">
									{post.data.tags.slice(0, 3).map(tag => (
										<span class="tag">#{tag.toUpperCase()}</span>
									))}
								</div>
								<h2 class="card-title">{post.data.title}</h2>
								{post.data.description && (
									<p class="card-desc">{post.data.description}</p>
								)}
								<div class="card-footer">
									<span class="card-date">
										{post.data.pubDate.toLocaleDateString('id-ID', {
											year: 'numeric', month: 'short', day: 'numeric'
										}).toUpperCase()}
									</span>
									<span class="card-read">BACA →</span>
								</div>
							</div>
						</a>
					))}
				</div>
			) : (
				<div class="empty-state gsap-reveal">
					<code>// PIPELINE INITIALIZING — FIRST SIGNAL INCOMING 08:00 WIB</code>
				</div>
			)}
		</section>
	</main>
</Layout>

<style>
	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 160px 40px 80px;
	}

	/* HERO */
	.hero { text-align: center; margin-bottom: 60px; }
	.hero-title {
		font-size: clamp(40px, 6vw, 72px);
		font-weight: 600;
		letter-spacing: -0.04em;
		line-height: 1;
		margin-bottom: 20px;
		color: var(--fg);
	}
	.hero-sub {
		font-size: clamp(15px, 2vw, 18px);
		color: var(--muted);
		font-weight: 300;
	}

	/* STATS BAR */
	.stats-bar {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 16px;
		padding: 12px;
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
		margin-bottom: 60px;
		font-family: monospace;
		font-size: 11px;
		letter-spacing: 2px;
		color: var(--muted);
	}
	.stats-divider { opacity: 0.3; }

	/* GRID */
	.report-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
		gap: 2px;
	}

	/* CARD */
	.report-card {
		background: #080808;
		border: 1px solid var(--border);
		text-decoration: none;
		color: inherit;
		display: flex;
		flex-direction: column;
		transition: border-color 0.3s ease, background 0.3s ease;
		overflow: hidden;
	}
	.report-card:hover {
		border-color: rgba(255,255,255,0.25);
		background: #0f0f0f;
	}
	.report-card:hover .card-read {
		opacity: 1;
	}

	/* THUMBNAIL */
	.card-thumb {
		width: 100%;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background: #111;
	}
	.card-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
		filter: brightness(0.85);
	}
	.report-card:hover .card-thumb img {
		transform: scale(1.04);
		filter: brightness(1);
	}

	/* CARD CONTENT */
	.card-content {
		padding: 28px 28px 24px;
		display: flex;
		flex-direction: column;
		flex: 1;
		gap: 12px;
	}

	.card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}
	.tag {
		font-family: monospace;
		font-size: 9px;
		color: var(--muted);
		letter-spacing: 1.5px;
		opacity: 0.6;
	}

	.card-title {
		font-size: 18px;
		font-weight: 600;
		line-height: 1.4;
		color: var(--fg);
		letter-spacing: -0.01em;
	}

	.card-desc {
		font-size: 13px;
		color: var(--muted);
		line-height: 1.6;
		font-weight: 300;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card-footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-top: auto;
		padding-top: 16px;
		border-top: 1px solid var(--border);
	}
	.card-date {
		font-family: monospace;
		font-size: 9px;
		color: var(--muted);
		letter-spacing: 1px;
		opacity: 0.6;
	}
	.card-read {
		font-family: monospace;
		font-size: 9px;
		letter-spacing: 2px;
		color: var(--fg);
		opacity: 0;
		transition: opacity 0.3s;
	}

	/* EMPTY STATE */
	.empty-state {
		text-align: center;
		padding: 120px 0;
		color: var(--muted);
		font-family: monospace;
		font-size: 13px;
		letter-spacing: 1px;
	}

	@media (max-width: 768px) {
		.container { padding: 120px 24px 60px; }
		.hero { margin-bottom: 48px; }
		.stats-bar { flex-wrap: wrap; gap: 8px; font-size: 9px; }
		.report-grid { grid-template-columns: 1fr; gap: 1px; }
		.card-content { padding: 20px; }
	}
</style>
