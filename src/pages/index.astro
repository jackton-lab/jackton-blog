---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = "Intelligence Archive";
---

<Layout title={title}>
	<main class="container">
		<!-- HERO SECTION -->
		<section class="hero gsap-reveal">
			<h1 class="hero-title">Intelligence Archive.</h1>
			<p class="hero-sub">Property market signals. Surfaced daily by Jackton.</p>
		</section>

		<!-- STATS BAR -->
		<div class="stats-bar gsap-reveal">
			<span class="stats-item">SISTEM AKTIF</span>
			<span class="stats-divider">·</span>
			<span class="stats-item">PIPELINE 24/7</span>
			<span class="stats-divider">·</span>
			<span class="stats-item">blog.jackton.xyz</span>
		</div>

		<!-- GRID SECTION -->
		<section class="archive-section">
			{posts.length > 0 ? (
				<div class="report-grid">
					{posts.map((post) => (
						<a href={`/blog/${post.slug}`} class="report-card gsap-reveal">
							<div class="card-content">
								<h2 class="card-title">{post.data.title}</h2>
								<div class="card-meta">
									<span class="card-date">{post.data.pubDate.toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric' }).toUpperCase()}</span>
									<div class="card-tags">
										{post.data.tags.map(tag => <span class="tag">#{tag.toUpperCase()}</span>)}
									</div>
								</div>
							</div>
						</a>
					))}
				</div>
			) : (
				<div class="empty-state gsap-reveal">
					<code>// PIPELINE INITIALIZING — FIRST SIGNAL INCOMING 08:00 WIB</code>
				</div>
			)}
		</section>
	</main>
</Layout>

<style>
	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 160px 40px 80px;
	}

	/* HERO */
	.hero {
		text-align: center;
		margin-bottom: 80px;
	}
	.hero-title {
		font-size: clamp(40px, 6vw, 72px);
		font-weight: 600;
		letter-spacing: -0.04em;
		line-height: 1;
		margin-bottom: 24px;
		color: var(--fg);
	}
	.hero-sub {
		font-size: clamp(16px, 2vw, 20px);
		color: var(--muted);
		font-weight: 300;
	}

	/* STATS BAR */
	.stats-bar {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 16px;
		padding: 12px;
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
		margin-bottom: 60px;
		font-family: monospace;
		font-size: 11px;
		letter-spacing: 2px;
		color: var(--muted);
	}
	.stats-divider {
		opacity: 0.3;
	}

	/* GRID */
	.report-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
		gap: 24px;
	}
	.report-card {
		background: #0a0a0a;
		border: 1px solid var(--border);
		padding: 32px;
		text-decoration: none;
		transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		min-height: 200px;
	}
	.report-card:hover {
		border-color: #fff;
		transform: translateY(-4px);
	}
	.card-title {
		font-size: 20px;
		font-weight: 500;
		line-height: 1.4;
		color: var(--fg);
		margin-bottom: 40px;
	}
	.card-meta {
		display: flex;
		flex-direction: column;
		gap: 12px;
	}
	.card-date {
		font-family: monospace;
		font-size: 10px;
		color: var(--muted);
		letter-spacing: 1px;
	}
	.card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}
	.tag {
		font-family: monospace;
		font-size: 10px;
		color: var(--accent);
		opacity: 0.7;
	}

	/* EMPTY STATE */
	.empty-state {
		text-align: center;
		padding: 100px 0;
		color: var(--muted);
		font-family: monospace;
		font-size: 13px;
		letter-spacing: 1px;
	}

	@media (max-width: 768px) {
		.container { padding: 120px 24px 60px; }
		.hero { margin-bottom: 60px; }
		.stats-bar { flex-wrap: wrap; gap: 8px; font-size: 9px; }
		.report-grid { grid-template-columns: 1fr; }
	}
</style>
