---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Intelligence Archive">
  <main>

    <section class="header">
      <p class="label">JACKTON INTELLIGENCE</p>
      <h1>Market<br/>Signals.</h1>
      <p class="sub">Insight properti Indonesia — dikurasi dan dianalisis setiap hari.</p>
    </section>

    <section class="grid-section">
      {posts.length > 0 ? (
        <div class="grid">
          {posts.map((post, i) => (
            <a href={`/blog/${post.slug}`} class={`card ${i === 0 ? 'card--lead' : ''}`}>
              <div class="card-image">
                {post.data.heroImage
                  ? <img src={post.data.heroImage} alt={post.data.title} loading={i < 3 ? 'eager' : 'lazy'} />
                  : <div class="card-image--empty" />
                }
              </div>
              <div class="card-body">
                <p class="card-date">
                  {post.data.pubDate.toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}
                </p>
                <h2 class="card-title">{post.data.title}</h2>
                <p class="card-desc">{post.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="empty">
          <p>Pipeline aktif — artikel pertama terbit 08:00 WIB.</p>
        </div>
      )}
    </section>

  </main>
</Layout>

<style>
  main {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 32px 120px;
  }

  /* ── HEADER ─────────────────────────────── */
  .header {
    padding: 160px 0 80px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 72px;
  }
  .label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 3px;
    color: var(--muted);
    margin-bottom: 28px;
  }
  .header h1 {
    font-size: clamp(56px, 8vw, 104px);
    font-weight: 500;
    letter-spacing: -0.045em;
    line-height: 0.95;
    color: var(--fg);
    margin-bottom: 28px;
  }
  .sub {
    font-size: 15px;
    color: var(--muted);
    font-weight: 300;
    max-width: 380px;
    line-height: 1.6;
  }

  /* ── GRID ────────────────────────────────── */
  .grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  /* ── CARD ────────────────────────────────── */
  .card {
    background: var(--bg);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    grid-column: span 4;
    transition: background 0.25s;
    overflow: hidden;
  }
  .card:hover { background: #0c0c0c; }
  .card:hover .card-image img { transform: scale(1.03); }

  /* Lead card — primeiro artigo ocupa 8 colunas */
  .card--lead {
    grid-column: span 8;
    flex-direction: row;
  }
  .card--lead .card-image {
    width: 55%;
    aspect-ratio: auto;
    flex-shrink: 0;
    height: 100%;
  }
  .card--lead .card-body { padding: 40px 36px; }
  .card--lead .card-title { font-size: 24px; }

  /* ── CARD IMAGE ──────────────────────────── */
  .card-image {
    aspect-ratio: 16/10;
    overflow: hidden;
    background: #0d0d0d;
    flex-shrink: 0;
  }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 1 !important;
    filter: brightness(0.85) saturate(0.75);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .card-image--empty {
    width: 100%;
    height: 100%;
    background: #0d0d0d;
  }

  /* ── CARD BODY ───────────────────────────── */
  .card-body {
    padding: 28px 28px 32px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }
  .card-date {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 1px;
    color: var(--muted);
    opacity: 0.5;
  }
  .card-title {
    font-size: 17px;
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: -0.02em;
    color: var(--fg);
  }
  .card-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.65;
    font-weight: 300;
    opacity: 0.7;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── EMPTY ───────────────────────────────── */
  .empty {
    padding: 120px 0;
    text-align: center;
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 1px;
    opacity: 0.4;
  }

  /* ── RESPONSIVE ──────────────────────────── */
  @media (max-width: 900px) {
    main { padding: 0 20px 80px; }
    .header { padding: 120px 0 60px; }
    .grid { grid-template-columns: 1fr; }
    .card, .card--lead { grid-column: span 1; flex-direction: column; }
    .card--lead .card-image { width: 100%; height: auto; }
    .card--lead .card-body { padding: 24px; }
  }
</style>
